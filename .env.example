# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง (อย่า commit .env ขึ้น git)

# Token ของบอท -> Developer Portal > Bot > Reset Token
DISCORD_TOKEN=

# Application ID -> Developer Portal > General Information > Application ID
CLIENT_ID=

# ID ของเซิร์ฟเวอร์เทสต์ -> คลิกขวาที่ชื่อ server > Copy Server ID
# (ต้องเปิด Developer Mode ใน Discord: Settings > Advanced > Developer Mode)
GUILD_ID=
